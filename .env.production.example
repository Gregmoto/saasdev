# ── Auto-provided by Railway ──────────────────────────────────────────────────
# These are set automatically when you add PostgreSQL / Redis services in Railway
# DATABASE_URL=postgresql://...
# REDIS_URL=redis://...

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Your Railway-generated domain for the API service
# e.g. https://saasshop-api.up.railway.app
BASE_DOMAIN=yourdomain.com

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SESSION_SECRET=REPLACE_WITH_SECURE_RANDOM_64_CHAR_HEX
SESSION_TTL_SECONDS=86400

# ── Admin panel ───────────────────────────────────────────────────────────────
# URL to the deployed API (Railway public domain for the api service)
NEXT_PUBLIC_API_URL=https://YOUR-API-DOMAIN.up.railway.app

# ── Search (optional) ────────────────────────────────────────────────────────
MEILISEARCH_HOST=
MEILISEARCH_MASTER_KEY=

# ── File storage (Cloudflare R2 / AWS S3) ────────────────────────────────────
S3_ENDPOINT=https://YOUR-ACCOUNT.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=saasshop-media
S3_PUBLIC_URL=https://media.yourdomain.com

# ── Email (Resend rekommenderas) ─────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@yourdomain.com

# ── Error tracking (optional) ────────────────────────────────────────────────
SENTRY_DSN=
