# App
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
BASE_DOMAIN=saasshop.local   # subdomains: {slug}.saasshop.local

# Database
DATABASE_URL=postgres://saasshop:saasshop@localhost:5432/saasshop

# Redis
REDIS_URL=redis://localhost:6379

# Session — must be at least 32 chars, keep secret
SESSION_SECRET=change-me-to-a-random-32-char-string!!
SESSION_TTL_SECONDS=86400

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=

# S3-compatible storage
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=saasshop-media
S3_PUBLIC_URL=

# Email — Resend
RESEND_API_KEY=
EMAIL_FROM=noreply@saasshop.local

# SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sentry (optional)
SENTRY_DSN=
